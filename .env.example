# Anthropic / Azure AI
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_BASE_URL=https://your-azure-endpoint.services.ai.azure.com/anthropic
ANTHROPIC_MODEL=claude-sonnet-4-5

# Database
DATABASE_URL=sqlite:///./aea.db

# Jira
JIRA_WEBHOOK_SECRET=           # leave blank to skip signature verification
JIRA_BASE_URL=https://your-org.atlassian.net/
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_BOT_ACCOUNT_ID=your-bot-account-id

# GitHub
GITHUB_TOKEN=ghp_your-github-token-here
# Secret to verify GitHub webhook signatures (GitHub repo → Settings → Webhooks → Secret)
GITHUB_WEBHOOK_SECRET=
GITHUB_REPO=                   # leave blank — repo is read from Jira labels (repo:owner/name)
GITHUB_DEV_BRANCH=dev          # default PR target branch
GITHUB_BRANCH=main
GITHUB_REPO_PATH_FILTER=       # optional: filter file tree to a subfolder e.g. src/

# Slack
SLACK_WEBHOOK_URL=         # Slack Incoming Webhook URL — leave blank to disable notifications
